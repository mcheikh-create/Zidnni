# Zidni — environment configuration
# Copy this file to .env and fill in real values. Never commit .env.

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Qwen3: primary path (local Ollama) ---
# Run `ollama serve` and `ollama pull qwen3:32b` first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# --- Qwen3: fallback path (OpenRouter) ---
# Used only when Ollama is unreachable. Get a key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-32b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Identity layer ---
# When true, every Qwen response is run through identity verification before
# reaching the user. Disable only for debugging.
IDENTITY_FILTER_ENABLED=true

# --- Session / auth ---
# Phase 1 uses a simple shared secret for session signing.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# --- Phase 2A: database, JWT, Stripe ---
DATABASE_URL=./zidnni.db
JWT_SECRET=change-this-in-production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PERSONAL=price_...
STRIPE_PRICE_BUSINESS=price_...
OTP_BYPASS_DEV=1234

# --- LLM API keys (model benchmark + intelligent routing) ---
# Run: node scripts/test-models.js  to compare all models
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Model routing defaults (used by backend/services/llm-router.js) ---
# free tier always uses local Ollama (OLLAMA_MODEL above)
# personal tier: DeepSeek V3 first, Gemini Flash as fallback (cheapest API options)
# business tier: Claude Haiku first (best quality), DeepSeek as fallback
DEFAULT_FREE_MODEL=qwen3:8b
DEFAULT_PERSONAL_MODEL=deepseek-chat
DEFAULT_BUSINESS_MODEL=claude-haiku-4-5
