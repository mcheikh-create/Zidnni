# Zidni — environment configuration
# Copy this file to .env and fill in real values. Never commit .env.

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Qwen3: primary path (local Ollama) ---
# Run `ollama serve` and `ollama pull qwen3:32b` first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# --- Qwen3: fallback path (OpenRouter) ---
# Used only when Ollama is unreachable. Get a key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-32b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Identity layer ---
# When true, every Qwen response is run through identity verification before
# reaching the user. Disable only for debugging.
IDENTITY_FILTER_ENABLED=true

# --- Session / auth ---
# Phase 1 uses a simple shared secret for session signing.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production
